# Required
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# Optional summary feature
ENABLE_SUMMARY=false
OPENAI_API_KEY=
SUMMARY_MODEL=
SUMMARY_DEFAULT_LANGUAGE=en

# Transcription
TRANSCRIPTION_MODEL=turbo
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_CPU_THREADS=4
WHISPER_NUM_WORKERS=1
WHISPER_LANGUAGE=auto
WHISPER_BEAM_SIZE=5
WHISPER_BEST_OF=1
WHISPER_VAD_FILTER=true
WHISPER_VAD_MIN_SILENCE_DURATION_MS=700
WHISPER_CONDITION_ON_PREVIOUS_TEXT=false
HF_TOKEN=
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# Limits
MAX_MEDIA_MINUTES=60
MAX_FILE_SIZE_MB=25
MAX_TRANSCRIPT_CHARS=120000

# Runtime
TEMP_DIR=tmp
LOG_LEVEL=INFO
FFMPEG_BIN=ffmpeg

# Timeouts in seconds
DOWNLOAD_TIMEOUT_SEC=1200
CONVERSION_TIMEOUT_SEC=600
TRANSCRIPTION_TIMEOUT_SECONDS=1800

# Summary tuning, only used when ENABLE_SUMMARY=true
SUMMARY_TIMEOUT_SEC=120
SUMMARY_DIRECT_MAX_CHARS=11000
SUMMARY_CHUNK_CHARS=6000
SUMMARY_CHUNK_OVERLAP_CHARS=300
SUMMARY_MAX_OUTPUT_TOKENS=800
SUMMARY_PENDING_TTL_SEC=900

# Telegram output chunking
TELEGRAM_MESSAGE_CHUNK_SIZE=3900

# Optional Instagram auth
INSTAGRAM_COOKIE_FILE=
INSTAGRAM_COOKIES_FROM_BROWSER=
INSTAGRAM_COOKIES_TXT=
